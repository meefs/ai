{
	"name": "@cloudflare/gateway-core",
	"version": "0.0.0",
	"private": true,
	"description": "Private shared core for Cloudflare AI Gateway: provider registry, gateway-fetch/header builders, resumable-stream engine, and Workers AI SSE helpers. Source-only; bundled into its consumers.",
	"license": "MIT",
	"author": "Cloudflare Inc.",
	"type": "module",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "rm -rf dist && tsdown --config tsdown.config.ts",
		"format": "oxfmt --write .",
		"test": "vitest",
		"test:ci": "vitest --watch=false",
		"type-check": "tsc --noEmit"
	},
	"devDependencies": {
		"@ai-sdk/provider": "^4.0.1",
		"@cloudflare/workers-types": "^4.20260628.1",
		"tsdown": "^0.22.3",
		"typescript": "6.0.3"
	}
}
